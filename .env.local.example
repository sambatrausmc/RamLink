# Firebase Web SDK config. Copy this file to .env.local and replace the values.
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_with_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_app_id
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=replace_with_recaptcha_enterprise_site_key
FIREBASE_APP_CHECK_ENFORCED=false

# Firebase Admin SDK and provisioning scripts use Application Default Credentials.
# Keep the service-account JSON outside the repository and revoke it after provisioning.
FIREBASE_PROJECT_ID=replace_with_project_id
GOOGLE_APPLICATION_CREDENTIALS=replace_with_absolute_path_outside_repo

# Local-only demonstration account credentials.
# Use approved @farmingdale.edu testing addresses and strong unique passwords.
RAMLINK_STUDENT_EMAIL=
RAMLINK_STUDENT_PASSWORD=
RAMLINK_OFFICER_EMAIL=
RAMLINK_OFFICER_PASSWORD=
RAMLINK_ADMIN_EMAIL=
RAMLINK_ADMIN_PASSWORD=
