rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to confirm user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedFarmingdaleUser() {
      return isSignedIn() &&
        request.auth.token.email_verified == true &&
        request.auth.token.email is string &&
        request.auth.token.email.matches("^[^@ ]+@farmingdale[.]edu$");
    }

    // Helper to confirm user is accessing their own document ID
    function isSelf(userId) {
      return isVerifiedFarmingdaleUser() && request.auth.uid == userId;
    }

    // Checks if user profile exists in Firestore
    function userDocExists() {
      return isVerifiedFarmingdaleUser() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Retrieves active user profile document
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Verifies specific assigned role
    function hasRole(role) {
      return userDocExists() && userDoc().data.role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isOfficer() {
      return hasRole("clubOfficer");
    }

    // Confirms an officer manages the target clubId
    function managesClub(clubId) {
      return isAdmin() ||
        (isOfficer() &&
          "managedClubIds" in userDoc().data &&
          clubId in userDoc().data.managedClubIds);
    }

    function validText(value, maximumLength) {
      return value is string && value.size() > 0 && value.size() <= maximumLength;
    }

    function validCategory(value) {
      return value in [
        "Academic",
        "Business",
        "Community Service",
        "Culture",
        "Health",
        "Leadership",
        "Recreation",
        "Technology"
      ];
    }

    function validClubStatus(value) {
      return value in ["pending", "active", "suspended", "archived"];
    }

    function validMembershipMutation(data) {
      return !("membershipMutation" in data) ||
        (data.membershipMutation is map &&
          data.membershipMutation.keys().hasAll([
            "requestId",
            "studentId",
            "clubId",
            "countChange"
          ]) &&
          data.membershipMutation.keys().hasOnly([
            "requestId",
            "studentId",
            "clubId",
            "countChange"
          ]) &&
          validText(data.membershipMutation.requestId, 260) &&
          validText(data.membershipMutation.studentId, 128) &&
          validText(data.membershipMutation.clubId, 120) &&
          data.membershipMutation.countChange in [-1, 1]);
    }

    function validClubDocument(data) {
      return data.keys().hasAll([
          "name",
          "shortName",
          "category",
          "description",
          "meetingSchedule",
          "meetingLocation",
          "contactEmail",
          "tags",
          "memberCount",
          "status",
          "updatedAt"
        ]) &&
        data.keys().hasOnly([
          "name",
          "shortName",
          "category",
          "description",
          "meetingSchedule",
          "meetingLocation",
          "contactEmail",
          "tags",
          "memberCount",
          "status",
          "nextEventId",
          "isSuggested",
          "createdAt",
          "updatedAt",
          "membershipMutation"
        ]) &&
        validText(data.name, 160) &&
        validText(data.shortName, 30) &&
        validCategory(data.category) &&
        validText(data.description, 2000) &&
        validText(data.meetingSchedule, 160) &&
        validText(data.meetingLocation, 200) &&
        validText(data.contactEmail, 254) &&
        data.tags is list && data.tags.size() <= 12 &&
        data.memberCount is int &&
        data.memberCount >= 0 && data.memberCount <= 100000 &&
        validClubStatus(data.status) &&
        (!("nextEventId" in data) || validText(data.nextEventId, 120)) &&
        (!("isSuggested" in data) || data.isSuggested is bool) &&
        (!("createdAt" in data) || data.createdAt is timestamp) &&
        data.updatedAt is timestamp &&
        validMembershipMutation(data);
    }

    function validEventDocument(data) {
      return data.keys().hasAll([
          "clubId",
          "clubName",
          "title",
          "description",
          "date",
          "startTime",
          "endTime",
          "location",
          "rsvpCount",
          "updatedAt"
        ]) &&
        data.keys().hasOnly([
          "clubId",
          "clubName",
          "title",
          "description",
          "date",
          "startTime",
          "endTime",
          "location",
          "rsvpCount",
          "createdAt",
          "updatedAt"
        ]) &&
        validText(data.clubId, 120) &&
        validText(data.clubName, 160) &&
        validText(data.title, 160) &&
        validText(data.description, 2000) &&
        validText(data.date, 40) &&
        validText(data.startTime, 40) &&
        validText(data.endTime, 40) &&
        validText(data.location, 200) &&
        data.rsvpCount is int &&
        data.rsvpCount >= 0 && data.rsvpCount <= 100000 &&
        (!("createdAt" in data) || data.createdAt is timestamp) &&
        data.updatedAt is timestamp;
    }

    function validAnnouncementDocument(data) {
      return data.keys().hasAll([
          "clubId",
          "clubName",
          "title",
          "body",
          "priority",
          "updatedAt"
        ]) &&
        data.keys().hasOnly([
          "clubId",
          "clubName",
          "title",
          "body",
          "priority",
          "createdAt",
          "updatedAt"
        ]) &&
        validText(data.clubId, 120) &&
        validText(data.clubName, 160) &&
        validText(data.title, 160) &&
        validText(data.body, 2000) &&
        data.priority in ["normal", "important"] &&
        (!("createdAt" in data) || data.createdAt is timestamp) &&
        data.updatedAt is timestamp;
    }

    function validResourceDocument(data) {
      return data.keys().hasAll([
          "clubId",
          "title",
          "description",
          "type",
          "url",
          "updatedAt"
        ]) &&
        data.keys().hasOnly([
          "clubId",
          "title",
          "description",
          "type",
          "url",
          "updatedAt"
        ]) &&
        validText(data.clubId, 120) &&
        validText(data.title, 160) &&
        validText(data.description, 2000) &&
        data.type in ["Form", "Waiver", "Guide", "Link", "Document"] &&
        validText(data.url, 2048) &&
        data.updatedAt is timestamp;
    }

    function validInterestDocument(data) {
      return data.keys().hasAll(["name", "category"]) &&
        data.keys().hasOnly(["name", "category"]) &&
        validText(data.name, 100) &&
        validCategory(data.category);
    }

    function validStudentEditableFields(data) {
      return validText(data.displayName, 100) &&
        data.major is string && data.major.size() <= 120 &&
        data.classYear is string && data.classYear.size() <= 60 &&
        data.interests is list && data.interests.size() <= 20 &&
        data.savedClubIds is list && data.savedClubIds.size() <= 100 &&
        data.savedEventIds is list && data.savedEventIds.size() <= 100 &&
        data.updatedAt == request.time;
    }

    function validInquiryDocument(data) {
      return data.keys().hasAll([
          "clubId",
          "clubName",
          "studentId",
          "studentName",
          "subject",
          "message",
          "status",
          "createdAt",
          "replies"
        ]) &&
        data.keys().hasOnly([
          "clubId",
          "clubName",
          "studentId",
          "studentName",
          "subject",
          "message",
          "status",
          "createdAt",
          "updatedAt",
          "replies"
        ]) &&
        validText(data.clubId, 120) &&
        validText(data.clubName, 160) &&
        validText(data.studentId, 128) &&
        validText(data.studentName, 100) &&
        validText(data.subject, 160) &&
        validText(data.message, 2000) &&
        data.status in ["open", "resolved"] &&
        data.createdAt is timestamp &&
        (!("updatedAt" in data) || data.updatedAt is timestamp) &&
        data.replies is list && data.replies.size() <= 50;
    }

    function validNotificationDocument(data) {
      return data.keys().hasAll([
          "userId",
          "title",
          "body",
          "type",
          "status",
          "relatedHref",
          "createdAt"
        ]) &&
        data.keys().hasOnly([
          "userId",
          "clubId",
          "title",
          "body",
          "type",
          "status",
          "relatedHref",
          "createdAt",
          "updatedAt"
        ]) &&
        validText(data.userId, 128) &&
        (!("clubId" in data) || validText(data.clubId, 120)) &&
        validText(data.title, 160) &&
        validText(data.body, 1000) &&
        data.type in ["event", "joinRequest", "announcement", "inquiry", "resource"] &&
        data.status in ["read", "unread"] &&
        validText(data.relatedHref, 500) &&
        data.createdAt is timestamp &&
        (!("updatedAt" in data) || data.updatedAt is timestamp);
    }

    // Couples officer membership edits to the matching request and club count.
    function officerUpdatesManagedMembership(userId) {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      let oldClubs = resource.data.joinedClubIds.toSet();
      let newClubs = request.resource.data.joinedClubIds.toSet();
      let addedClubs = newClubs.difference(oldClubs);
      let removedClubs = oldClubs.difference(newClubs);
      let mutation = request.resource.data.membershipMutation;
      let requestPath = /databases/$(database)/documents/joinRequests/$(mutation.requestId);
      let clubPath = /databases/$(database)/documents/clubs/$(mutation.clubId);
      return isOfficer() &&
        "membershipMutation" in request.resource.data &&
        mutation.requestId is string &&
        mutation.studentId == userId &&
        mutation.clubId is string &&
        mutation.clubId in userDoc().data.managedClubIds &&
        mutation.countChange in [-1, 1] &&
        changedFields.hasOnly([
          "joinedClubIds",
          "membershipMutation",
          "updatedAt"
        ]) &&
        exists(requestPath) &&
        existsAfter(requestPath) &&
        get(requestPath).data.studentId == userId &&
        get(requestPath).data.clubId == mutation.clubId &&
        exists(clubPath) &&
        existsAfter(clubPath) &&
        getAfter(clubPath).data.memberCount ==
          get(clubPath).data.memberCount + mutation.countChange &&
        (
          (mutation.countChange == 1 &&
            get(requestPath).data.status != "approved" &&
            getAfter(requestPath).data.status == "approved" &&
            addedClubs.hasOnly([mutation.clubId]) &&
            addedClubs.size() == 1 &&
            removedClubs.size() == 0) ||
          (mutation.countChange == -1 &&
            get(requestPath).data.status == "approved" &&
            getAfter(requestPath).data.status != "approved" &&
            removedClubs.hasOnly([mutation.clubId]) &&
            removedClubs.size() == 1 &&
            addedClubs.size() == 0)
        );
    }

    // Officers may only view students who belong to one of their managed clubs.
    function officerCanReadManagedMember() {
      return isOfficer() &&
        resource.data.joinedClubIds.hasAny(userDoc().data.managedClubIds);
    }

    // Students may edit their profile and activity fields, but not roles or memberships.
    function selfUpdatesAllowedProfileFields(userId) {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      return isSelf(userId) &&
        request.resource.data.role == resource.data.role &&
        validStudentEditableFields(request.resource.data) &&
        changedFields.hasOnly([
          "displayName",
          "major",
          "classYear",
          "interests",
          "savedClubIds",
          "savedEventIds",
          "updatedAt"
        ]);
    }

    function validNewStudentProfile(userId) {
      let data = request.resource.data;
      return isSelf(userId) &&
        data.keys().hasAll([
          "id",
          "role",
          "displayName",
          "email",
          "major",
          "classYear",
          "interests",
          "joinedClubIds",
          "savedClubIds",
          "savedEventIds",
          "rsvpedEventIds",
          "managedClubIds",
          "createdAt",
          "updatedAt"
        ]) &&
        data.keys().hasOnly([
          "id",
          "role",
          "displayName",
          "email",
          "major",
          "classYear",
          "interests",
          "joinedClubIds",
          "savedClubIds",
          "savedEventIds",
          "rsvpedEventIds",
          "managedClubIds",
          "createdAt",
          "updatedAt"
        ]) &&
        data.id == userId &&
        data.role == "student" &&
        data.email == request.auth.token.email &&
        data.displayName is string &&
        data.displayName.size() > 0 &&
        data.displayName.size() <= 100 &&
        data.major is string && data.major.size() <= 120 &&
        data.classYear is string && data.classYear.size() <= 60 &&
        data.interests is list && data.interests.size() <= 20 &&
        data.joinedClubIds == [] &&
        data.savedClubIds == [] &&
        data.savedEventIds == [] &&
        data.rsvpedEventIds == [] &&
        data.managedClubIds == [] &&
        data.createdAt == request.time &&
        data.updatedAt == request.time;
    }

    function studentUpdatesOwnRsvpProfile(userId) {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      let previousRsvps = resource.data.rsvpedEventIds.toSet();
      let nextRsvps = request.resource.data.rsvpedEventIds.toSet();
      let addedRsvps = nextRsvps.difference(previousRsvps);
      let removedRsvps = previousRsvps.difference(nextRsvps);
      let mutation = request.resource.data.rsvpMutation;
      let eventPath = /databases/$(database)/documents/events/$(mutation.eventId);
      return isSelf(userId) &&
        "rsvpMutation" in request.resource.data &&
        mutation.eventId is string &&
        mutation.countChange in [-1, 1] &&
        changedFields.hasOnly(["rsvpedEventIds", "rsvpMutation", "updatedAt"]) &&
        exists(eventPath) &&
        existsAfter(eventPath) &&
        getAfter(eventPath).data.rsvpCount ==
          get(eventPath).data.rsvpCount + mutation.countChange &&
        (
          (mutation.countChange == 1 &&
            addedRsvps.hasOnly([mutation.eventId]) &&
            addedRsvps.size() == 1 &&
            removedRsvps.size() == 0) ||
          (mutation.countChange == -1 &&
            removedRsvps.hasOnly([mutation.eventId]) &&
            removedRsvps.size() == 1 &&
            addedRsvps.size() == 0)
        );
    }

    function studentUpdatesOwnRsvp(eventId) {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      let previousRsvps = userDoc().data.rsvpedEventIds.toSet();
      let nextUser = getAfter(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
      let nextRsvps = nextUser.data.rsvpedEventIds.toSet();
      let addedRsvps = nextRsvps.difference(previousRsvps);
      let removedRsvps = previousRsvps.difference(nextRsvps);
      let mutation = nextUser.data.rsvpMutation;
      let countChange = request.resource.data.rsvpCount - resource.data.rsvpCount;
      return isVerifiedFarmingdaleUser() &&
        "rsvpMutation" in nextUser.data &&
        mutation.eventId == eventId &&
        mutation.countChange == countChange &&
        request.resource.data.rsvpCount >= 0 &&
        changedFields.hasOnly(["rsvpCount", "updatedAt"]) &&
        (
          (countChange == 1 &&
            addedRsvps.hasOnly([eventId]) &&
            addedRsvps.size() == 1 &&
            removedRsvps.size() == 0) ||
          (countChange == -1 &&
            removedRsvps.hasOnly([eventId]) &&
            removedRsvps.size() == 1 &&
            addedRsvps.size() == 0)
        );
    }

    function validNewJoinRequest(requestId) {
      let data = request.resource.data;
      return isVerifiedFarmingdaleUser() &&
        data.keys().hasAll([
          "clubId",
          "clubName",
          "studentId",
          "studentName",
          "message",
          "status",
          "createdAt",
          "updatedAt"
        ]) &&
        data.keys().hasOnly([
          "clubId",
          "clubName",
          "studentId",
          "studentName",
          "message",
          "status",
          "createdAt",
          "updatedAt"
        ]) &&
        requestId == request.auth.uid + "_" + data.clubId &&
        data.clubId is string &&
        data.clubId.size() > 0 && data.clubId.size() <= 120 &&
        validText(data.clubName, 160) &&
        data.studentId == request.auth.uid &&
        validText(data.studentName, 100) &&
        data.message is string && data.message.size() <= 1000 &&
        data.status == "pending" &&
        data.createdAt == request.time &&
        data.updatedAt == request.time;
    }

    function studentReopensRejectedRequest(requestId) {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      return isVerifiedFarmingdaleUser() &&
        resource.data.studentId == request.auth.uid &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.clubId == resource.data.clubId &&
        requestId == request.auth.uid + "_" + resource.data.clubId &&
        resource.data.status == "rejected" &&
        request.resource.data.status == "pending" &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 1000 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        changedFields.hasOnly(["message", "status", "createdAt", "updatedAt"]);
    }

    function officerUpdatesJoinRequestStatus() {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      let studentPath = /databases/$(database)/documents/users/$(resource.data.studentId);
      let clubPath = /databases/$(database)/documents/clubs/$(resource.data.clubId);
      return managesClub(resource.data.clubId) &&
        request.resource.data.clubId == resource.data.clubId &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.status in ["approved", "rejected"] &&
        changedFields.hasOnly(["status", "updatedAt"]) &&
        (
          (resource.data.status != "approved" &&
            request.resource.data.status != "approved") ||
          (resource.data.status == "approved" &&
            request.resource.data.status == "approved") ||
          (resource.data.status != "approved" &&
            request.resource.data.status == "approved" &&
            !(resource.data.clubId in get(studentPath).data.joinedClubIds) &&
            resource.data.clubId in getAfter(studentPath).data.joinedClubIds &&
            getAfter(clubPath).data.memberCount ==
              get(clubPath).data.memberCount + 1) ||
          (resource.data.status == "approved" &&
            request.resource.data.status != "approved" &&
            resource.data.clubId in get(studentPath).data.joinedClubIds &&
            !(resource.data.clubId in getAfter(studentPath).data.joinedClubIds) &&
            getAfter(clubPath).data.memberCount ==
              get(clubPath).data.memberCount - 1)
        );
    }

    function officerUpdatesMembershipCount(clubId) {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      let mutation = request.resource.data.membershipMutation;
      let requestPath = /databases/$(database)/documents/joinRequests/$(mutation.requestId);
      let studentPath = /databases/$(database)/documents/users/$(mutation.studentId);
      let countChange = request.resource.data.memberCount - resource.data.memberCount;
      return isOfficer() &&
        "membershipMutation" in request.resource.data &&
        mutation.requestId is string &&
        mutation.studentId is string &&
        mutation.clubId == clubId &&
        clubId in userDoc().data.managedClubIds &&
        mutation.countChange in [-1, 1] &&
        countChange == mutation.countChange &&
        request.resource.data.memberCount >= 0 &&
        changedFields.hasOnly([
          "memberCount",
          "membershipMutation",
          "updatedAt"
        ]) &&
        exists(requestPath) &&
        existsAfter(requestPath) &&
        get(requestPath).data.studentId == mutation.studentId &&
        get(requestPath).data.clubId == clubId &&
        (
          (countChange == 1 &&
            get(requestPath).data.status != "approved" &&
            getAfter(requestPath).data.status == "approved" &&
            !(clubId in get(studentPath).data.joinedClubIds) &&
            clubId in getAfter(studentPath).data.joinedClubIds) ||
          (countChange == -1 &&
            get(requestPath).data.status == "approved" &&
            getAfter(requestPath).data.status != "approved" &&
            clubId in get(studentPath).data.joinedClubIds &&
            !(clubId in getAfter(studentPath).data.joinedClubIds))
        );
    }

    // Officers may edit club profile details, but lifecycle and count fields stay admin-only.
    function officerUpdatesManagedClubProfile(clubId) {
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      return isOfficer() &&
        "managedClubIds" in userDoc().data &&
        clubId in userDoc().data.managedClubIds &&
        changedFields.hasOnly([
          "name",
          "shortName",
          "category",
          "description",
          "meetingSchedule",
          "meetingLocation",
          "contactEmail",
          "tags",
          "updatedAt"
        ]);
    }

    function validNewReport() {
      let data = request.resource.data;
      return isVerifiedFarmingdaleUser() &&
        data.keys().hasAll([
          "reporterId",
          "reporterName",
          "contentType",
          "contentTitle",
          "reason",
          "status",
          "createdAt",
          "updatedAt"
        ]) &&
        data.keys().hasOnly([
          "reporterId",
          "reporterName",
          "contentType",
          "contentTitle",
          "reason",
          "status",
          "createdAt",
          "updatedAt"
        ]) &&
        data.reporterId == request.auth.uid &&
        data.reporterName is string &&
        data.reporterName.size() > 0 &&
        data.reporterName.size() <= 100 &&
        data.contentType in ["Announcement", "Event", "Resource", "Club Profile"] &&
        data.contentTitle is string &&
        data.contentTitle.size() > 0 &&
        data.contentTitle.size() <= 160 &&
        data.reason is string &&
        data.reason.size() > 0 &&
        data.reason.size() <= 2000 &&
        data.status == "new" &&
        data.createdAt == request.time &&
        data.updatedAt == request.time;
    }

    function validNewAuditLog() {
      let data = request.resource.data;
      let adminActions = [
        "admin.club_created",
        "admin.club_status_updated",
        "admin.report_status_updated",
        "admin.user_clubs_updated",
        "admin.user_role_updated"
      ];
      let officerActions = [
        "officer.announcement_created",
        "officer.announcement_deleted",
        "officer.announcement_updated",
        "officer.club_profile_updated",
        "officer.event_created",
        "officer.event_deleted",
        "officer.event_updated",
        "officer.inquiry_replied",
        "officer.inquiry_resolved",
        "officer.join_request_updated",
        "officer.resource_created",
        "officer.resource_deleted",
        "officer.resource_updated"
      ];
      return isVerifiedFarmingdaleUser() &&
        data.keys().hasAll([
          "actorId",
          "actorRole",
          "action",
          "targetType",
          "targetId",
          "createdAt"
        ]) &&
        data.keys().hasOnly([
          "actorId",
          "actorRole",
          "action",
          "targetType",
          "targetId",
          "clubId",
          "createdAt"
        ]) &&
        data.actorId == request.auth.uid &&
        data.actorRole == userDoc().data.role &&
        data.action is string &&
        data.targetType is string &&
        data.targetType.size() > 0 &&
        data.targetType.size() <= 80 &&
        data.targetId is string &&
        data.targetId.size() > 0 &&
        data.targetId.size() <= 160 &&
        (!("clubId" in data) || data.clubId is string) &&
        data.createdAt == request.time &&
        ((data.actorRole == "admin" && data.action in adminActions) ||
          (data.actorRole == "clubOfficer" && data.action in officerActions));
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isAdmin() &&
        validClubDocument(request.resource.data) &&
        request.resource.data.status == "pending" &&
        request.resource.data.memberCount == 0 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if validClubDocument(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        (isAdmin() ||
          officerUpdatesManagedClubProfile(clubId) ||
          officerUpdatesMembershipCount(clubId));
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if managesClub(request.resource.data.clubId) &&
        validEventDocument(request.resource.data) &&
        request.resource.data.rsvpCount == 0 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if validEventDocument(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        ((managesClub(resource.data.clubId) &&
          request.resource.data.clubId == resource.data.clubId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "title",
            "description",
            "date",
            "startTime",
            "endTime",
            "location",
            "updatedAt"
          ])) ||
          studentUpdatesOwnRsvp(eventId));
      allow delete: if managesClub(resource.data.clubId);
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if managesClub(request.resource.data.clubId) &&
        validAnnouncementDocument(request.resource.data) &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if managesClub(resource.data.clubId) &&
        request.resource.data.clubId == resource.data.clubId &&
        validAnnouncementDocument(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "title",
          "body",
          "priority",
          "updatedAt"
        ]);
      allow delete: if managesClub(resource.data.clubId);
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow create: if managesClub(request.resource.data.clubId) &&
        validResourceDocument(request.resource.data) &&
        request.resource.data.updatedAt == request.time;
      allow update: if managesClub(resource.data.clubId) &&
        request.resource.data.clubId == resource.data.clubId &&
        validResourceDocument(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "title",
          "description",
          "type",
          "url",
          "updatedAt"
        ]);
      allow delete: if managesClub(resource.data.clubId);
    }

    match /interests/{interestId} {
      allow read: if true;
      allow create, update: if isAdmin() && validInterestDocument(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if validNewStudentProfile(userId);
      allow read: if isSelf(userId) || isAdmin() || officerCanReadManagedMember();
      allow update: if
        selfUpdatesAllowedProfileFields(userId) ||
        studentUpdatesOwnRsvpProfile(userId) ||
        isAdmin() ||
        officerUpdatesManagedMembership(userId);
      allow delete: if isAdmin();
    }

    match /joinRequests/{requestId} {
      allow create: if validNewJoinRequest(requestId);
      allow read: if isVerifiedFarmingdaleUser() &&
        (resource.data.studentId == request.auth.uid || managesClub(resource.data.clubId));
      allow update: if
        officerUpdatesJoinRequestStatus() ||
        studentReopensRejectedRequest(requestId);
      allow delete: if isAdmin() ||
        (isVerifiedFarmingdaleUser() &&
          resource.data.studentId == request.auth.uid &&
          resource.data.status == "pending");
    }

    match /inquiries/{inquiryId} {
      allow create: if isVerifiedFarmingdaleUser() &&
        validInquiryDocument(request.resource.data) &&
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.status == "open" &&
        request.resource.data.replies == [] &&
        request.resource.data.createdAt == request.time;
      allow read: if isVerifiedFarmingdaleUser() &&
        (resource.data.studentId == request.auth.uid || managesClub(resource.data.clubId));
      allow update: if managesClub(resource.data.clubId) &&
        validInquiryDocument(request.resource.data) &&
        request.resource.data.clubId == resource.data.clubId &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.status in ["open", "resolved"] &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["replies", "status", "updatedAt"]);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Allows self-notifications, admin alerts, or officer alerts sent from managed clubs
      allow create: if isVerifiedFarmingdaleUser() &&
        validNotificationDocument(request.resource.data) &&
        request.resource.data.createdAt == request.time &&
        (request.resource.data.userId == request.auth.uid ||
          isAdmin() ||
          ("clubId" in request.resource.data && managesClub(request.resource.data.clubId)));
      allow read: if isVerifiedFarmingdaleUser() &&
        resource.data.userId == request.auth.uid;
      // Users can only mark their own notifications read/unread
      allow update: if isVerifiedFarmingdaleUser() &&
        validNotificationDocument(request.resource.data) &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.status in ["read", "unread"] &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"]);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if validNewReport();
      allow read, update, delete: if isAdmin();
    }

    match /auditLogs/{auditLogId} {
      allow create: if validNewAuditLog();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /rateLimits/{rateLimitId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
