rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Checks if the user is interacting with their own user document
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Confirms the user's profile exists in the database
    function userDocExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Reads the authenticated user's Firestore profile data
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Verifies the user holds a specific assigned role
    function hasRole(role) {
      return userDocExists() && userDoc().data.role == role;
    }
    
    function isAdmin() {
      return hasRole("admin");
    }
    
    function isOfficer() {
      return hasRole("clubOfficer");
    }
    
    // Checks if an officer is explicitly assigned to manage the target clubId
    function managesClub(clubId) {
      return isAdmin() || (isOfficer() && "managedClubIds" in userDoc().data && clubId in userDoc().data.managedClubIds);
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || managesClub(clubId);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if managesClub(request.resource.data.clubId);
      allow update, delete: if managesClub(resource.data.clubId);
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if managesClub(request.resource.data.clubId);
      allow update, delete: if managesClub(resource.data.clubId);
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow create: if managesClub(request.resource.data.clubId);
      allow update, delete: if managesClub(resource.data.clubId);
    }

    match /interests/{interestId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Students can create their own profile as a student, but only Admins can elevate roles
    match /users/{userId} {
      allow create: if isSelf(userId) && request.resource.data.role == "student";
      allow read: if isSelf(userId) || isAdmin();
      allow update: if (isSelf(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /joinRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || managesClub(resource.data.clubId));
      allow update: if managesClub(resource.data.clubId);
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || managesClub(resource.data.clubId));
      allow update: if managesClub(resource.data.clubId);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // Deny all other unmatched paths by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
