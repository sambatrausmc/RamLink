{
  "name": "ramlink",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:rules": "npx --yes firebase-tools@15.23.0 emulators:exec \"vitest --run tests/firestore-rules.test.ts\" --only firestore --project demo-ramlink",
    "provision:check": "node scripts/provision-demo-data.mjs --dry-run",
    "provision:data": "node --env-file=.env.local scripts/provision-demo-data.mjs --confirm-project=csc325-firebase-app",
    "provision:accounts": "node --env-file=.env.local scripts/provision-test-accounts.mjs --confirm-project=csc325-firebase-app",
    "provision:workflows": "node --env-file=.env.local scripts/provision-demo-workflows.mjs --confirm-project=csc325-firebase-app",
    "provision:all": "npm run provision:data && npm run provision:accounts && npm run provision:workflows",
    "migrate:profiles:check": "node --env-file=.env.local scripts/migrate-user-profile-schema.mjs --confirm-project=csc325-firebase-app",
    "migrate:profiles": "node --env-file=.env.local scripts/migrate-user-profile-schema.mjs --confirm-project=csc325-firebase-app --apply"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "gaxios": "7.2.0",
    "postcss": "$postcss",
    "retry-request": "8.0.3",
    "teeny-request": "10.1.3"
  }
}
